generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  SUB
  MANAGER
  COACH
  ANALYTICS
}

enum LoLRole {
  TOP
  JUNGLE
  MID
  ADC
  SUPPORT
  FILL
}

enum EventType {
  MATCH
  CWL
  TITANS
  TRAINING
  SCRIM
  MEETING
  OTHER
}

enum MatchResult {
  WIN
  LOSS
}

enum MatchStatus {
  SCHEDULED
  PLAYED
}

enum DraftStatus {
  PLANNING
  READY
  PLAYED
}

enum Side {
  RED
  BLUE
}

enum GameType {
  OFFICIAL
  TRAINING
  SCRIM
}

enum PickBanType {
  PICK
  BAN
}

enum LoLRegion {
  WEST
  EAST
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  role      UserRole @default(PLAYER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  player    Player?
}

model Player {
  id             String               @id @default(cuid())
  externalId     String?              @unique
  userId         String?              @unique
  user           User?                @relation(fields: [userId], references: [id])
  displayName    String
  summonerName   String?
  teamRole       LoLRole
  memberRole     UserRole             @default(PLAYER)
  active         Boolean              @default(true)
  participations MatchParticipant[]
  mvpMatches     Match[]              @relation("MatchMvp")
  availability   AvailabilitySlot[]
  tierlists      Tierlist[]
  accounts       PlayerAccount[]
  updatedAt      DateTime             @updatedAt @default(now())
}

model PlayerAccount {
  id           String    @id @default(cuid())
  playerId     String
  player       Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  region       LoLRegion
  summonerName String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt @default(now())

  @@unique([playerId, summonerName])
  @@index([playerId, region])
}

model Event {
  id          String    @id @default(cuid())
  externalId  String?   @unique
  title       String
  type        EventType
  startAt     DateTime
  endAt       DateTime?
  description String?
  location    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt @default(now())
}

model Match {
  id             String               @id @default(cuid())
  externalId     String?              @unique
  playedAt       DateTime
  league         String
  opponent       String?
  status         MatchStatus          @default(PLAYED)
  result         MatchResult?
  side           Side
  gameType       GameType             @default(OFFICIAL)
  gameDurationSec Int?
  notes          String?
  source         String?
  mvpId          String?
  mvp            Player?              @relation("MatchMvp", fields: [mvpId], references: [id])
  participants   MatchParticipant[]
  pickBans       PickBan[]
  draft          DraftSession?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt @default(now())
}

model MatchParticipant {
  id       String  @id @default(cuid())
  matchId  String
  match    Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId String
  player   Player  @relation(fields: [playerId], references: [id])
  champion String
  side     Side?
  /** In-game lane from match data: TOP, JUNGLE, MIDDLE, BOTTOM, UTILITY */
  position String?
  kills    Int?
  deaths   Int?
  assists  Int?
  cs          Int?
  damage      Int?
  goldEarned  Int?
  visionScore Int?
  /** JSON: itemIds, spell1Id, spell2Id, perks — see ParticipantBuild in ingest types */
  buildJson   String?
}

model PickBan {
  id        String      @id @default(cuid())
  matchId   String
  match     Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  champion  String
  type      PickBanType
  side      Side
  order     Int         @default(0)
}

model AvailabilitySlot {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  weekStart DateTime
  slots     String
  updatedAt DateTime @updatedAt

  @@unique([playerId, weekStart])
}

model Tierlist {
  id        String   @id @default(cuid())
  name      String
  category  String   @default("champions")
  rows      String
  playerId  String?
  player    Player?  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([playerId])
}

model DraftSession {
  id          String       @id @default(cuid())
  title       String       @default("Untitled draft")
  opponent    String?
  league      String       @default("Scrim")
  scheduledAt DateTime     @default(now())
  ourSide     Side         @default(BLUE)
  status      DraftStatus  @default(PLANNING)
  /** Ordered pick/ban entries: [{ champion, type, side, order }] */
  pickBans    String       @default("[]")
  notes       String?
  matchId     String?      @unique
  match       Match?       @relation(fields: [matchId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt @default(now())
}

model IngestRun {
  id        String   @id @default(cuid())
  source    String?
  summary   String
  success   Boolean  @default(true)
  createdAt DateTime @default(now())
}
